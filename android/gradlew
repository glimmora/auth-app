#!/bin/sh
# Gradle wrapper script
# This script downloads and runs Gradle if not installed

GRADLE_VERSION="8.0"
GRADLE_HOME="$HOME/.gradle/wrapper/dists/gradle-${GRADLE_VERSION}-bin"
GRADLE_BIN="$GRADLE_HOME/gradle-${GRADLE_VERSION}/bin/gradle"

if [ ! -f "$GRADLE_BIN" ]; then
    echo "Gradle not found. Downloading Gradle ${GRADLE_VERSION}..."
    mkdir -p "$GRADLE_HOME"
    wget -q "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -O "/tmp/gradle-${GRADLE_VERSION}.zip"
    unzip -q "/tmp/gradle-${GRADLE_VERSION}.zip" -d "$GRADLE_HOME"
    rm "/tmp/gradle-${GRADLE_VERSION}.zip"
fi

exec "$GRADLE_BIN" "$@"
