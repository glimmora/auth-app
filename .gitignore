# =============================================================================
# AuthVault .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Flutter / Dart
# ---------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
*.g.dart
*.freezed.dart

# Flutter ephemeral / generated
flutter/linux/flutter/ephemeral/
!flutter/linux/flutter/ephemeral/.gitkeep
flutter/ios/Pods/
flutter/ios/.symlinks/
flutter/ios/Flutter/Flutter.framework
flutter/ios/Flutter/Flutter.podspec
flutter/ios/Flutter/Generated.xcconfig
flutter/ios/Flutter/.*.sh
flutter/ios/**/build/

# ---------------------------------------------------------------------------
# Android
# ---------------------------------------------------------------------------
flutter/android/.gradle/
flutter/android/app/build/
flutter/android/.idea/
flutter/android/**/local.properties
flutter/android/key.properties
android/.gradle/
android/captures/
android/gradlew.bat
android/local.properties
android/**/build/
android/app/build/
android/.idea/
android/**/local.properties
android/key.properties
*.iml

# ---------------------------------------------------------------------------
# iOS
# ---------------------------------------------------------------------------
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Debug.xcconfig
ios/Flutter/Release.xcconfig
ios/**/build/
*.xcworkspace
!*.xcworkspace
*.xcodeproj
!*.xcodeproj
*.pbxuser
!default.pbxuser
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ---------------------------------------------------------------------------
# Web / Node.js
# ---------------------------------------------------------------------------
web/node_modules/
web/.vite/
web/.env
web/.env.local
web/.env.*.local
web/package-lock.json
web/yarn.lock
web/yarn-error.log*

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Cache / Temp
# ---------------------------------------------------------------------------
.cache/
**/.cache/
tmp/
**/tmp/
temp/
**/temp/
*.tmp
*.temp
*.log
**/*.log
!scripts/*.log

# ---------------------------------------------------------------------------
# Backups
# ---------------------------------------------------------------------------
backups/
**/backups/
*.bak
*.backup
*.old
.cache

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template

# ---------------------------------------------------------------------------
# Keystore (never commit private keys)
# ---------------------------------------------------------------------------
scripts/keystore/*.keystore
scripts/keystore/*.jks
scripts/keystore/.keystore_pass
scripts/keystore/*.p12
scripts/keystore/*.pfx
**/*.keystore
**/*.jks
**/.keystore_pass

# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
coverage/
**/coverage/
*.lcov
test/.test_coverage.dart
coverage/lcov.info

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
Thumbs.db

# ---------------------------------------------------------------------------
# Documentation build output
# ---------------------------------------------------------------------------
docs/_build/
site/

# ---------------------------------------------------------------------------
# Exceptions — files we WANT to track
# ---------------------------------------------------------------------------
!scripts/keystore/.gitkeep
!scripts/keystore/README.md
!.env.example
!.env.template
!BUILD_SIZES.md
!backup.sh
