# =============================================================================
# AuthVault - Comprehensive .gitignore
# Prevents build artifacts, caches, and temporary files from being committed
# =============================================================================

# ------------------------------------------------------------------------------
# Flutter / Dart
# ------------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
# NOTE: build/ and **/build/ removed — Flutter build outputs are tracked
# so that BUILD_SIZES.md can be pushed to the repository.
# Specific sub-build caches are still ignored below.
*.lock

# Generated code (auto-generated by build_runner)
*.g.dart
*.freezed.dart

# Flutter Linux ephemeral (auto-generated)
flutter/linux/flutter/ephemeral/
!flutter/linux/flutter/ephemeral/.gitkeep

# Flutter iOS generated
flutter/ios/Pods/
flutter/ios/.symlinks/
flutter/ios/Flutter/Flutter.framework
flutter/ios/Flutter/Flutter.podspec
flutter/ios/Flutter/Generated.xcconfig
flutter/ios/Flutter/.*.sh
flutter/ios/**/build/
*.xcworkspace
!*.xcworkspace
*.xcodeproj
!*.xcodeproj
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ------------------------------------------------------------------------------
# Android
# ------------------------------------------------------------------------------
android/.gradle/
android/captures/
android/gradlew.bat
android/local.properties
android/**/build/
android/app/build/
android/.idea/
*.iml
android/**/local.properties
android/key.properties

# ------------------------------------------------------------------------------
# iOS
# ------------------------------------------------------------------------------
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Debug.xcconfig
ios/Flutter/Release.xcconfig
ios/**/build/
*.xcworkspace
!*.xcworkspace
*.xcodeproj
!*.xcodeproj
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ------------------------------------------------------------------------------
# Web / Node.js
# ------------------------------------------------------------------------------
web/node_modules/
# NOTE: web/dist/ and web/build/ are NOT ignored — build outputs are tracked
# for BUILD_SIZES.md reporting.
web/.vite/
web/.env
web/.env.local
web/.env.*.local
web/package-lock.json
web/yarn.lock
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*

# ------------------------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Cache and Temporary Files
# ------------------------------------------------------------------------------
.cache/
**/.cache/
tmp/
**/tmp/
temp/
**/temp/
*.tmp
*.temp
*.log
**/*.log
!scripts/*.log

# ------------------------------------------------------------------------------
# Scripts - Keystore and Sensitive Data
# ------------------------------------------------------------------------------
scripts/keystore/*.keystore
scripts/keystore/*.jks
scripts/keystore/.keystore_pass
scripts/keystore/*.p12
scripts/keystore/*.pfx
**/*.keystore
**/*.jks
**/.keystore_pass

# ------------------------------------------------------------------------------
# Build Outputs — Flutter Android/iOS sub-build caches (ignore)
# Main flutter/build/ and web/build/ are tracked for size reporting.
# ------------------------------------------------------------------------------
flutter/ios/Pods/
flutter/android/app/build/
flutter/android/.gradle/

# NOTE: web/dist/ removed from ignore — tracked for build size reporting.

# ------------------------------------------------------------------------------
# Testing and Coverage
# ------------------------------------------------------------------------------
coverage/
**/coverage/
*.lcov
test/.test_coverage.dart
coverage/lcov.info

# ------------------------------------------------------------------------------
# Speculos / Ledger (if present)
# ------------------------------------------------------------------------------
speculos/
*.elf
*.hex
build/nanos/
build/nanox/
build/nanos2/
build/stax/

# ------------------------------------------------------------------------------
# Backup Files
# ------------------------------------------------------------------------------
*.bak
*.backup
*.old
backups/
**/backups/
.cache

# ------------------------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template

# ------------------------------------------------------------------------------
# Documentation Build (if applicable)
# ------------------------------------------------------------------------------
docs/_build/
site/

# ------------------------------------------------------------------------------
# OS Generated Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Keep these directories but ignore contents
# ------------------------------------------------------------------------------
# Cache directory structure (keep empty dirs)
.cache/**/*
!cache/.gitkeep

# ------------------------------------------------------------------------------
# Exceptions - Files we WANT to track
# ------------------------------------------------------------------------------
# Keep pubspec.lock for Flutter web (optional - uncomment if needed)
# !pubspec.lock

# Keep keystore directory structure
!scripts/keystore/.gitkeep

# Keep important config files
!.env.example
!scripts/keystore/README.md

# Keep build size report and backup script
!BUILD_SIZES.md
!backup.sh
