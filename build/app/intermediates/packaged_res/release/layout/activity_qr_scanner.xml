<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Akun"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih metode untuk menambahkan akun:"
        android:textSize="16sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnScanQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷 Scan QR Code"
        android:layout_marginBottom="12dp"
        android:padding="16dp" />

    <Button
        android:id="@+id/btnImportImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🖼️ Import dari Gambar"
        android:layout_marginBottom="12dp"
        android:padding="16dp" />

    <Button
        android:id="@+id/btnManualEntry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⌨️ Entry Manual"
        android:padding="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan QR code dari layanan yang mendukung otpauth://"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="24dp"
        android:gravity="center" />

</LinearLayout>
